{
  "name": "paytm-money-mcp",
  "version": "1.0.0",
  "description": "MCP server for Paytm Money - portfolio & market data",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "axios": "^1.7.9",
    "zod": "^3.24.2"
  },
  "license": "MIT",
  "keywords": [
    "mcp",
    "paytm",
    "trading",
    "stocks",
    "model-context-protocol",
    "ai",
    "copilot",
    "finance"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/couragecowardlydog/paytm-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/couragecowardlydog/paytm-mcp-server/issues"
  },
  "homepage": "https://github.com/couragecowardlydog/paytm-mcp-server#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.2",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nock": "^14.0.1",
    "prettier": "^3.8.3",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  }
}
